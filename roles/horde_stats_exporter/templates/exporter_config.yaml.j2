# AI Horde Prometheus Exporter Configuration
# Managed by Ansible - do not edit manually

scrape_intervals:
  models: {{ horde_stats_exporter_scrape_models }}
  workers: {{ horde_stats_exporter_scrape_workers }}
  performance: {{ horde_stats_exporter_scrape_performance }}
  stats: {{ horde_stats_exporter_scrape_stats }}
  modes: {{ horde_stats_exporter_scrape_modes }}
  teams: {{ horde_stats_exporter_scrape_teams }}

api:
  base_url: "{{ horde_stats_exporter_api_base_url }}"
  user_agent: "{{ horde_stats_exporter_user_agent }}"
  timeout: {{ horde_stats_exporter_api_timeout }}

exporter:
  port: {{ horde_stats_exporter_port }}
  log_level: {{ horde_stats_exporter_log_level }}
