# {{ ansible_managed }}
# AI-Horde environment — rendered by Ansible
# Permissions: 0600 root:root (contains secrets)

PROFILE=docker
REDIS_IP=redis
REDIS_SERVERS='["redis"]'
USE_SQLITE=0

POSTGRES_URL=postgres
POSTGRES_USER={{ ai_horde_postgres_user }}
POSTGRES_PASS={{ ai_horde_postgres_password }}

secret_key={{ ai_horde_secret_key }}

ADMINS='{{ ai_horde_admins | to_json }}'

{% for key, value in ai_horde_env_overrides.items() %}
{{ key }}={{ value }}
{% endfor %}
