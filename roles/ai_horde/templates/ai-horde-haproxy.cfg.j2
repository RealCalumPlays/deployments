# {{ ansible_managed }}
# HAProxy configuration for AI-Horde native multi-instance deployment.

global
    log /dev/log local0
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  {{ ai_horde_haproxy_timeout_server }}

frontend ai_horde_front
    bind {{ ai_horde_haproxy_listen }}:{{ ai_horde_haproxy_port }}
    default_backend ai_horde_back

backend ai_horde_back
    balance roundrobin
    option httpchk GET /api/v2/status/heartbeat
    http-check expect status 200
{% for port in range(ai_horde_port | int, ai_horde_port | int + ai_horde_instance_count | int) %}
    server aihorde-{{ port }} {{ ai_horde_backend_host }}:{{ port }} check inter 10s fall 3 rise 2
{% endfor %}
