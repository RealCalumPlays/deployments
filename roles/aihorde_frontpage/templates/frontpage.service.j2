[Unit]
Description=AiHordeFrontpage (Docker Compose)
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory={{ aihorde_frontpage_base_dir }}
{% if aihorde_frontpage_docker_build_on_service_start | bool %}
ExecStartPre=/usr/bin/docker compose build
{% endif %}
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
RemainAfterExit=yes
Restart=on-failure
RestartSec=10s
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
