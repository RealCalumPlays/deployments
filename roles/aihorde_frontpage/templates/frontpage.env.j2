# {{ ansible_managed }}
# AiHordeFrontpage environment — rendered by Ansible

{% if aihorde_frontpage_deploy_mode == 'docker' %}
# In Docker mode the container always listens on 8006 internally.
# The host-side port is controlled by the compose port mapping.
PORT=8006
{% else %}
PORT={{ aihorde_frontpage_port }}
{% endif %}
NODE_ENV=production
NG_ALLOWED_HOSTS={{ aihorde_frontpage_allowed_hosts | default(['localhost', '127.0.0.1', '::1']) | join(',') }}
